{
  "name": "@prodigy/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint ok'",
    "test": "vitest run",
    "db:push": "prisma db push",
    "db:seed": "tsx src/seed/index.ts",
    "db:reset": "prisma db push --force-reset && tsx src/seed/index.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^8.3.1",
    "@prisma/client": "^5.13.0",
    "@prodigy/schemas": "workspace:*",
    "@prodigy/types": "workspace:*",
    "fastify": "^4.26.2",
    "nanoid": "^5.1.11",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "prisma": "^5.13.0",
    "tsx": "^4.8.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.3"
  }
}
